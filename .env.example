# Copie para .env e preencha. O docker-compose lê automaticamente.

# OpenAI — sem a chave o backend roda em fallback (feedback canned, perguntas do banco).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Auth — chave de assinatura dos JWTs. Em prod, USE uma chave forte (>=32 bytes random).
# Em dev, se vazio, o backend gera uma efêmera por processo (tokens invalidam no restart).
#   openssl rand -hex 32
JWT_SECRET=
